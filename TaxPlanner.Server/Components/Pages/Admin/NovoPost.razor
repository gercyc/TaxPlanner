@page "/admin/posts/novo"
@attribute [Authorize]
@inject BlogService BlogService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@rendermode InteractiveServer

<MudText Typo="Typo.h4" Class="mb-4" Color="Color.Primary">Nova Postagem</MudText>

<EditForm Model="_model" OnValidSubmit="Save">
    <MudGrid>
        @* ── Cover Image Section ────────────────────────────────────── *@
        <MudItem xs="12">
            <MudText Typo="Typo.subtitle2" Class="mb-2">
                <MudIcon Icon="@Icons.Material.Filled.Image" Class="mr-1" />Imagem de capa
            </MudText>
            <MudPaper Elevation="0" Class="pa-4 mb-3" Style="border: 1px solid var(--mud-palette-lines-default); border-radius: var(--tp-radius-md);">
                <MudTextField @bind-Value="_model.ThumbnailUrl"
                              Label="URL da imagem de capa"
                              Placeholder="https://exemplo.com/capa.jpg"
                              Variant="Variant.Outlined" Class="mb-3" FullWidth="true"
                              Immediate="true" />

                <div class="mb-3 d-flex align-center flex-wrap" style="gap: 8px;">
                    <MudButton HtmlTag="label" for="upload-cover-input-novo"
                               Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Upload"
                               Disabled="_coverUploading">
                        @(_coverUploading ? "Enviando..." : "Fazer upload da capa")
                    </MudButton>
                    <InputFile id="upload-cover-input-novo"
                               OnChange="HandleCoverUpload"
                               accept=".jpg,.jpeg,.png,.gif,.webp,.svg"
                               hidden
                               disabled="@_coverUploading" />
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        Ou cole a URL de uma imagem pública acima. JPG, PNG, GIF, WebP, SVG até 5 MB.
                    </MudText>
                </div>

                <MudTextField @bind-Value="_model.ThumbnailAlt"
                              Label="Texto alternativo (acessibilidade)"
                              Placeholder="Descreva a imagem para leitores de tela"
                              Variant="Variant.Outlined" Class="mb-3" FullWidth="true"
                              HelperText="Recomendado. Lido por leitores de tela." />

                <MudPaper Elevation="1" Class="pa-2 mb-3" Style="border-radius: var(--tp-radius-md); overflow: hidden;">
                    @if (!string.IsNullOrWhiteSpace(_model.ThumbnailUrl))
                    {
                        <img src="@_model.ThumbnailUrl" alt="@_model.ThumbnailAlt"
                             loading="lazy"
                             style="width: 100%; height: 240px; object-fit: cover; display: block; border-radius: var(--tp-radius-md);" />
                    }
                    else
                    {
                        <div class="d-flex align-center justify-center" style="height: 240px; color: var(--mud-palette-text-secondary);">
                            <MudText Typo="Typo.body2">Sem capa definida.</MudText>
                        </div>
                    }
                </MudPaper>

                @if (!string.IsNullOrWhiteSpace(_model.ThumbnailUrl))
                {
                    <MudButton OnClick="ClearCover" Variant="Variant.Outlined" Color="Color.Error"
                               StartIcon="@Icons.Material.Filled.Delete" Size="Size.Small">
                        Remover capa
                    </MudButton>
                }
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="8">
            <MudTextField @bind-Value="_model.Title" Label="Título" Required="true" RequiredError="Título é obrigatório"
                          Variant="Variant.Outlined" Class="mb-3" FullWidth="true"
                          OnBlur="GenerateSlugIfEmpty" />
        </MudItem>
        <MudItem xs="12" md="4">
            <MudTextField @bind-Value="_model.Slug" Label="Slug" Required="true" RequiredError="Slug é obrigatório"
                          Variant="Variant.Outlined" Class="mb-3" HelperText="URL amigável. Ex: meu-primeiro-post">
            </MudTextField>
        </MudItem>

        <MudItem xs="12">
            <MudTextField @bind-Value="_model.Summary" Label="Resumo" Variant="Variant.Outlined" Class="mb-3" FullWidth="true"
                          Lines="2" HelperText="Aparece nos cards de listagem (opcional)" />
        </MudItem>

        <MudItem xs="12">
            <MudTextField @bind-Value="_model.Tags" Label="Tags" Variant="Variant.Outlined" Class="mb-3" FullWidth="true"
                          HelperText="Separadas por vírgula. Ex: dotnet, blazor, aspnetcore" />
        </MudItem>

        <MudItem xs="12" md="6">
            <MudText Typo="Typo.subtitle2" Class="mb-2">Markdown</MudText>
            <MudTextField @bind-Value="_contentMarkdown" Variant="Variant.Outlined"
                          Lines="20" FullWidth="true" Class="mb-3" Immediate="true" />
        </MudItem>

        <MudItem xs="12" md="6">
            <MudText Typo="Typo.subtitle2" Class="mb-2">Preview</MudText>
            <MudPaper Elevation="1" Class="pa-4" MinHeight="480" MaxHeight="600" Style="overflow-y: auto;">
                @if (string.IsNullOrWhiteSpace(_previewHtml))
                {
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        O preview aparecerá aqui conforme você digita...
                    </MudText>
                }
                else
                {
                    <MudText Typo="Typo.body1">
                        @((MarkupString)_previewHtml)
                    </MudText>
                }
            </MudPaper>
        </MudItem>

        @* ── Image Upload Section ────────────────────────────────────── *@
        <MudItem xs="12">
            <MudDivider Class="mb-4" />
            <MudText Typo="Typo.subtitle2" Class="mb-2">
                <MudIcon Icon="@Icons.Material.Filled.Image" Class="mr-1" />Imagens do conteúdo
            </MudText>

            <div class="mb-4">
                <MudButton HtmlTag="label" for="upload-image-input-novo"
                           Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Upload"
                           Disabled="_uploading">
                    @(_uploading ? "Enviando..." : "Fazer Upload de Imagem")
                </MudButton>
                <InputFile id="upload-image-input-novo"
                           OnChange="HandleImageUpload"
                           accept=".jpg,.jpeg,.png,.gif,.webp,.svg"
                           hidden
                           disabled="@_uploading" />
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-2 d-inline-block">
                    JPG, PNG, GIF, WebP, SVG até 5 MB
                </MudText>
            </div>

            @if (_images is not null && _images.Count > 0)
            {
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var img in _images)
                    {
                        <MudPaper Elevation="1" Class="pa-2" Style="width: 150px;">
                            <img src="@img.Url" alt="@img.FileName"
                                 style="width: 100%; height: 100px; object-fit: cover; border-radius: 4px; cursor: pointer;"
                                 @onclick="() => InsertImageMarkdown(img.Url, img.FileName)"
                                 title="Clique para inserir no markdown" />
                            <div class="d-flex justify-space-between align-center mt-1">
                                <MudText Typo="Typo.caption" Class="text-truncate" Style="max-width: 90px;" title="@img.FileName">
                                    @img.FileName
                                </MudText>
                                <MudIconButton Icon="@Icons.Material.Filled.ContentCopy"
                                               Size="Size.Small"
                                               OnClick="@(() => CopyUrlToClipboard(img.Url))"
                                               title="Copiar URL" />
                                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                               Size="Size.Small"
                                               Color="Color.Error"
                                               OnClick="@(() => DeleteImage(img.FileName))"
                                               title="Eliminar imagem" />
                            </div>
                        </MudPaper>
                    }
                </div>
            }
            else if (_images is not null)
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Nenhuma imagem enviada ainda.
                </MudText>
            }
        </MudItem>

        <MudItem xs="12">
            <MudDivider Class="mb-4" />
            <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Save">
                Salvar Rascunho
            </MudButton>
            <MudButton OnClick="SaveAndPublish" Variant="Variant.Filled" Color="Color.Success"
                       StartIcon="@Icons.Material.Filled.Publish" Class="ml-2">
                Salvar e Publicar
            </MudButton>
            <MudButton Href="/admin/posts" Variant="Variant.Text" Color="Color.Secondary" Class="ml-2">
                Cancelar
            </MudButton>
        </MudItem>
    </MudGrid>
</EditForm>

@code {
    private PostCreateModel _model = new();
    private string _previewHtml = string.Empty;
    private bool _slugAutoGenerated = true;
    private List<BlogService.ImageInfo>? _images;
    private bool _uploading;
    private bool _coverUploading;

    private string _contentMarkdown
    {
        get => _model.ContentMarkdown;
        set
        {
            _model.ContentMarkdown = value;
            _slugAutoGenerated = false;
            _previewHtml = RenderMarkdown(value);
        }
    }

    private class PostCreateModel
    {
        public string Title { get; set; } = string.Empty;
        public string Slug { get; set; } = string.Empty;
        public string? Summary { get; set; }
        public string ContentMarkdown { get; set; } = string.Empty;
        public string? Tags { get; set; }
        public string? ThumbnailUrl { get; set; }
        public string? ThumbnailAlt { get; set; }
    }

    protected override void OnInitialized()
    {
        LoadImages();
    }

    private void LoadImages()
    {
        _images = BlogService.GetImages();
    }

    private async Task HandleImageUpload(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) return;

        _uploading = true;
        try
        {
            var ext = Path.GetExtension(file.Name).ToLowerInvariant();

            if (!BlogService.AllowedImageExtensions.Contains(ext))
            {
                Snackbar.Add($"Formato não permitido: {ext}. Use JPG, PNG, GIF, WebP ou SVG.", Severity.Error);
                return;
            }

            if (file.Size > BlogService.MaxImageSize)
            {
                Snackbar.Add($"Ficheiro muito grande ({file.Size / 1024} KB). Máximo: 5 MB.", Severity.Error);
                return;
            }

            await using var stream = file.OpenReadStream(BlogService.MaxImageSize);
            var url = await BlogService.UploadImageAsync(stream, file.Name, file.ContentType);

            Snackbar.Add($"Imagem enviada: {file.Name}", Severity.Success);

            // Insert markdown at the end of the content
            var markdown = $"\n![{file.Name}]({url})\n";
            _model.ContentMarkdown += markdown;
            _previewHtml = RenderMarkdown(_model.ContentMarkdown);

            LoadImages();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erro ao enviar imagem: {ex.Message}", Severity.Error);
        }
        finally
        {
            _uploading = false;
        }
    }

    private async Task HandleCoverUpload(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) return;

        _coverUploading = true;
        try
        {
            var ext = Path.GetExtension(file.Name).ToLowerInvariant();

            if (!BlogService.AllowedImageExtensions.Contains(ext))
            {
                Snackbar.Add($"Formato não permitido: {ext}. Use JPG, PNG, GIF, WebP ou SVG.", Severity.Error);
                return;
            }

            if (file.Size > BlogService.MaxImageSize)
            {
                Snackbar.Add($"Ficheiro muito grande ({file.Size / 1024} KB). Máximo: 5 MB.", Severity.Error);
                return;
            }

            await using var stream = file.OpenReadStream(BlogService.MaxImageSize);
            var url = await BlogService.UploadImageAsync(stream, file.Name, file.ContentType);

            _model.ThumbnailUrl = url;
            Snackbar.Add($"Capa atualizada: {file.Name}", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erro ao enviar capa: {ex.Message}", Severity.Error);
        }
        finally
        {
            _coverUploading = false;
        }
    }

    private void ClearCover()
    {
        _model.ThumbnailUrl = null;
        _model.ThumbnailAlt = null;
        Snackbar.Add("Capa removida.", Severity.Info);
    }

    private void InsertImageMarkdown(string url, string alt)
    {
        var markdown = $"![{alt}]({url})";
        _model.ContentMarkdown += $"\n{markdown}\n";
        _previewHtml = RenderMarkdown(_model.ContentMarkdown);
        Snackbar.Add("Markdown inserido no editor.", Severity.Info);
    }

    private async Task CopyUrlToClipboard(string url)
    {
        var fullUrl = $"{Navigation.BaseUri.TrimEnd('/')}{url}";
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", fullUrl);
        Snackbar.Add("URL copiada!", Severity.Success);
    }

    private void DeleteImage(string fileName)
    {
        var deleted = BlogService.DeleteImage(fileName);
        if (deleted)
        {
            Snackbar.Add($"Imagem eliminada: {fileName}", Severity.Info);
            LoadImages();
        }
        else
        {
            Snackbar.Add($"Não foi possível eliminar: {fileName}", Severity.Error);
        }
    }

    private async Task Save()
    {
        try
        {
            await BlogService.CreateAsync(
                _model.Title,
                _model.Summary,
                _model.ContentMarkdown,
                _model.Tags,
                _model.Slug,
                _model.ThumbnailUrl,
                _model.ThumbnailAlt);
            Snackbar.Add("Rascunho salvo!", Severity.Success);
            Navigation.NavigateTo("/admin/posts");
        }
        catch (ArgumentException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task SaveAndPublish()
    {
        try
        {
            var post = await BlogService.CreateAsync(
                _model.Title,
                _model.Summary,
                _model.ContentMarkdown,
                _model.Tags,
                _model.Slug,
                _model.ThumbnailUrl,
                _model.ThumbnailAlt);
            await BlogService.PublishAsync(post.Id);
            Snackbar.Add("Postagem publicada!", Severity.Success);
            Navigation.NavigateTo("/admin/posts");
        }
        catch (ArgumentException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private void GenerateSlugIfEmpty()
    {
        if (_slugAutoGenerated || string.IsNullOrWhiteSpace(_model.Slug))
        {
            _model.Slug = GenerateSlug(_model.Title);
            _slugAutoGenerated = true;
        }
    }

    private static string GenerateSlug(string title)
    {
        var slug = title
            .ToLowerInvariant()
            .Replace(" ", "-")
            .Select(c => (char.IsLetterOrDigit(c) || c == '-') ? c.ToString() : "-")
            .Aggregate("", (a, b) => a + b);
        while (slug.Contains("--"))
            slug = slug.Replace("--", "-");
        return slug.Trim('-');
    }

    private static string RenderMarkdown(string markdown)
    {
        if (string.IsNullOrWhiteSpace(markdown)) return string.Empty;
        return Markdown.ToHtml(markdown, new MarkdownPipelineBuilder().UseAdvancedExtensions().Build());
    }
}
