<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <meta name="theme-color" content="#0F172A" id="tp-theme-color" />
    <ResourcePreloader />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" rel="stylesheet" />
    <link href="@Assets["_content/MudBlazor/MudBlazor.min.css"]" rel="stylesheet" />
    <link rel="stylesheet" href="css/app.css" />
    <link rel="stylesheet" href="@Assets["TaxPlanner.Server.styles.css"]" />
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet />
    <script>
        // Anti-flash: aplica a preferência de tema ANTES do primeiro paint,
        // lendo o localStorage. A troca real da paleta é feita pelo
        // MudThemeProvider reescrevendo o <style class="mud-theme-provider">;
        // este script apenas garante que o <body> chegue com a classe certa
        // para o MudBlazor e o seletor .mud-theme-dark, e que o meta
        // theme-color reflita o estado sem flash.
        (function () {
            try {
                var isDark = localStorage.getItem('tp-theme-dark') === '1';
                if (isDark) {
                    document.body.classList.add('mud-theme-dark');
                }
                var meta = document.querySelector('meta[name="theme-color"]');
                if (meta) meta.setAttribute('content', isDark ? '#020617' : '#0F172A');
            } catch (e) { /* silencioso: cai no default claro */ }
        })();
    </script>
    <script>
        // Sincroniza o <meta name="theme-color"> com a preferência.
        // A troca visual da paleta é responsabilidade do MudThemeProvider
        // (que reescreve o <style class="mud-theme-provider">); este helper
        // apenas atualiza o meta tag, que o MudBlazor não controla.
        window.tpSetThemeMeta = function (isDark) {
            try {
                var meta = document.querySelector('meta[name="theme-color"]');
                if (meta) meta.setAttribute('content', isDark ? '#020617' : '#0F172A');
            } catch (e) { /* silencioso */ }
        };
    </script>
</head>

<body>
    <Routes />
    <ReconnectModal />
    <script src="@Assets["_content/MudBlazor/MudBlazor.min.js"]"></script>
    <script src="@Assets["_framework/blazor.web.js"]"></script>
    <script src="@Assets["Components/Account/Shared/PasskeySubmit.razor.js"]" type="module"></script>
</body>

</html>
