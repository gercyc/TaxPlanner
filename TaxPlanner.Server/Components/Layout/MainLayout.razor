@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using TaxPlanner.Server.Data
@using TaxPlanner.Server.Theme

<MudThemeProvider @bind-IsDarkMode="_isDarkMode" Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@((e) => DrawerToggle())" />
        <MudIcon Icon="@Icons.Material.Filled.EditNote" Class="mr-2" Size="Size.Medium" />
        <MudText Typo="Typo.h6" Class="font-weight-bold">TaxPlanner — Blog</MudText>
        <MudSpacer />
        <MudTooltip Text="@(_isDarkMode ? "Tema claro" : "Tema escuro")" Placement="Placement.Bottom">
            <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Outlined.LightMode : Icons.Material.Outlined.DarkMode)"
                           Color="Color.Inherit"
                           OnClick="ToggleTheme"
                           aria-label="Alternar tema" />
        </MudTooltip>
        <AuthorizeView>
            <Authorized>
                <MudText Typo="Typo.body2" Class="mr-2">
                    @context.User.Identity?.Name
                </MudText>
                <MudIconButton Icon="@Icons.Material.Filled.AccountCircle" Color="Color.Inherit" Href="/Account/Manage" />
            </Authorized>
            <NotAuthorized>
                <MudButton Href="/Account/Login" Color="Color.Inherit" Variant="Variant.Text">
                    Entrar
                </MudButton>
                <MudButton Href="/Account/Register" Color="Color.Inherit" Variant="Variant.Text">
                    Registrar
                </MudButton>
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2">
        <MudNavMenu Color="Color.Secondary">
            <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home">
                Início
            </MudNavLink>
            <MudNavLink Href="/admin/posts" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Article">
                Postagens
            </MudNavLink>
            <MudNavLink Href="/admin/posts/novo" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Add">
                Nova Postagem
            </MudNavLink>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="pt-2 pb-12">
            @Body
        </MudContainer>
    </MudMainContent>

    <MudContainer MaxWidth="MaxWidth.Large" Class="py-3">
        <MudDivider Class="mb-3" />
        <MudText Align="Align.Center" Typo="Typo.caption" Color="Color.Secondary">
            TaxPlanner Blog — © @DateTime.Now.Year
        </MudText>
    </MudContainer>
</MudLayout>

@code {
    [Inject] private IJSRuntime JS { get; set; } = default!;

    private bool _drawerOpen = true;
    private bool _isDarkMode;

    private readonly MudTheme _theme = TaxPlannerTheme.CreateTheme();

    private void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }

    private async Task ToggleTheme()
    {
        _isDarkMode = !_isDarkMode;
        await JS.InvokeVoidAsync("localStorage.setItem", "tp-theme-dark", _isDarkMode ? "1" : "0");
        await JS.InvokeVoidAsync("tpSetThemeMeta", _isDarkMode);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var stored = await JS.InvokeAsync<string?>("localStorage.getItem", "tp-theme-dark");
                if (stored == "1" && !_isDarkMode)
                {
                    _isDarkMode = true;
                    // Re-renderizar para que o MudThemeProvider reavalie
                    // @bind-IsDarkMode e reescreva o <style class="mud-theme-provider">
                    // com as variáveis da PaletteDark. Sem isso, a página fica presa
                    // no PaletteLight do pré-render (em SSR Blazor Server, o
                    // pré-render é estático e só este StateHasChanged força a
                    // hidratação a refletir o estado persistido).
                    StateHasChanged();
                }
            }
            catch
            {
                // localStorage indisponível: mantém o default (claro)
            }
        }
    }
}
