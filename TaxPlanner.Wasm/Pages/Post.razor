@page "/post/{Slug}"
@inject BlogService BlogService
@inject IJSRuntime JS

<PageTitle>@(_post?.Title ?? "Postagem") — TaxPlanner</PageTitle>

@if (_loading)
{
    <div class="tp-blog-loading">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
    </div>
}
else if (_post is null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">
        Postagem não encontrada.
    </MudAlert>
    <MudButton Href="/blog" Variant="Variant.Filled" Color="Color.Primary"
               StartIcon="@Icons.Material.Rounded.ArrowBack">
        Voltar ao Blog
    </MudButton>
}
else
{
    <article class="tp-article">
        <a href="/blog" class="tp-article-back">
            <MudIcon Icon="@Icons.Material.Rounded.ArrowBack" Size="Size.Small" />
            Voltar ao Blog
        </a>

        <header class="tp-article-header">
            <div class="tp-article-tags">
                @foreach (var tag in GetTags(_post.Tags))
                {
                    <span class="tp-tag">@tag</span>
                }
            </div>

            <h1 class="tp-article-title">@_post.Title</h1>

            @if (!string.IsNullOrWhiteSpace(_post.Summary))
            {
                <p class="tp-article-summary">@_post.Summary</p>
            }

            <div class="tp-article-meta">
                <span class="tp-article-meta-item">
                    <MudIcon Icon="@Icons.Material.Rounded.CalendarToday" Size="Size.Small" />
                    @_post.PublishedAt?.ToString("dd 'de' MMMM 'de' yyyy")
                </span>
                @if (_post.UpdatedAt is not null && _post.UpdatedAt != _post.PublishedAt)
                {
                    <span class="tp-meta-divider" aria-hidden="true">•</span>
                    <span class="tp-article-meta-item">
                        <MudIcon Icon="@Icons.Material.Rounded.Update" Size="Size.Small" />
                        Atualizado em @_post.UpdatedAt?.ToString("dd/MM/yyyy")
                    </span>
                }
            </div>
        </header>

        @if (!string.IsNullOrWhiteSpace(_post.ThumbnailUrl))
        {
            <figure class="tp-article-hero">
                <img src="@_post.ThumbnailUrl"
                     alt="@GetThumbnailAlt()"
                     loading="lazy" />
            </figure>
        }

        <div class="blog-content">
            @((MarkupString)_post.ContentHtml)
        </div>

        <footer class="tp-article-footer">
            <MudDivider Class="mb-4" />
            <MudButton Href="/blog" Variant="Variant.Outlined" Color="Color.Primary"
                       StartIcon="@Icons.Material.Rounded.ArrowBack">
                Voltar ao Blog
            </MudButton>
        </footer>
    </article>
}

@code {
    [Parameter]
    public string Slug { get; set; } = string.Empty;

    private BlogService.PostDetail? _post;
    private bool _loading = true;
    private bool _highlighted;

    protected override async Task OnInitializedAsync()
    {
        _post = await BlogService.GetPostAsync(Slug);
        _loading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_loading && _post is not null && !_highlighted)
        {
            _highlighted = true;
            await JS.InvokeVoidAsync("Prism.highlightAll");
        }
    }

    private static IEnumerable<string> GetTags(string? tags)
    {
        if (string.IsNullOrWhiteSpace(tags)) return Enumerable.Empty<string>();
        return tags
            .Split(',', StringSplitOptions.RemoveEmptyEntries)
            .Select(t => t.Trim())
            .Where(t => !string.IsNullOrWhiteSpace(t));
    }

    private string GetThumbnailAlt() =>
        !string.IsNullOrWhiteSpace(_post?.ThumbnailAlt)
            ? _post.ThumbnailAlt!
            : $"Imagem de capa: {_post?.Title}";
}
