@inherits LayoutComponentBase
@using TaxPlanner.Wasm.Theme

<MudThemeProvider @bind-IsDarkMode="_isDarkMode" Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Fixed="true">
        <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Class="mr-2" Size="Size.Medium" Color="Color.Primary" />
        <MudText Typo="Typo.h6" Class="font-weight-bold" Color="Color.Primary">TaxPlanner</MudText>
        <MudSpacer />
        <MudButton Href="/" Color="Color.Inherit" Variant="Variant.Text" StartIcon="@Icons.Material.Filled.Home">
            Início
        </MudButton>
        <MudButton Href="/analise-tributaria" Color="Color.Inherit" Variant="Variant.Text" StartIcon="@Icons.Material.Filled.Calculate">
            Análise Tributária
        </MudButton>
        <MudButton Href="/tabelas" Color="Color.Inherit" Variant="Variant.Text" StartIcon="@Icons.Material.Filled.TableChart">
            Tabelas
        </MudButton>
        <MudButton Href="/blog" Color="Color.Inherit" Variant="Variant.Text" StartIcon="@Icons.Material.Filled.Article">
            Blog
        </MudButton>
        <MudDivider Vertical="true" FlexItem="true" Class="mx-3 my-2" />
        <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                       Color="Color.Inherit"
                       OnClick="ToggleTheme"
                       title="Alternar entre tema claro e escuro" />
    </MudAppBar>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="pt-8 pb-12">
            @Body
        </MudContainer>
    </MudMainContent>

    <MudDivider />

    <MudContainer MaxWidth="MaxWidth.Large" Class="py-6">
        <MudGrid Justify="Justify.Center">
            <MudItem xs="12" md="10" lg="8">
                <MudAlert Severity="Severity.Info"
                          Variant="Variant.Outlined"
                          Dense="false"
                          Class="mb-4"
                          Icon="@Icons.Material.Filled.Security">
                    <MudText Typo="Typo.subtitle2" Class="font-weight-bold">Sua privacidade é garantida</MudText>
                    <MudText Typo="Typo.body2">
                        Não armazenamos nenhum dado seu. Todos os cálculos são realizados localmente no seu navegador.
                        Nenhuma informação pessoal, salarial ou fiscal é enviada para servidores externos.
                    </MudText>
                </MudAlert>
            </MudItem>
        </MudGrid>

        <MudText Align="Align.Center" Typo="Typo.caption" Color="Color.Secondary">
            TaxPlanner — Simulador de Imposto de Renda. Uso gratuito e sem registro.
        </MudText>
    </MudContainer>
</MudLayout>

@code {
    private readonly MudTheme _theme = ClaudeTheme.CreateTheme();
    private bool _isDarkMode;

    private void ToggleTheme()
    {
        _isDarkMode = !_isDarkMode;
    }
}
